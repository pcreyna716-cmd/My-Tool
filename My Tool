    private static void DrawPlacementPreview(Event e)
    {
        if (!quickMoveMode || Selection.activeGameObject == null || e.alt) return;

        Ray ray = HandleUtility.GUIPointToWorldRay(e.mousePosition);
        object snap = HandleUtility.RaySnap(ray);
        if (!(snap is RaycastHit hit)) return;

        GameObject selected = Selection.activeGameObject;
        MeshFilter[] meshFilters = selected.GetComponentsInChildren<MeshFilter>();
        if (meshFilters.Length == 0) return;

        Quaternion rotation = selected.transform.rotation;
        if (alignToNormal)
        {
            rotation = Quaternion.FromToRotation(Vector3.up, hit.normal) * rotation;
        }

        if (previewMeshMaterial == null)
        {
            Shader shader = Shader.Find("Hidden/Internal-Colored");
            if (shader != null)
            {
                previewMeshMaterial = new Material(shader)
                {
                    hideFlags = HideFlags.HideAndDontSave
                };
                previewMeshMaterial.SetInt("_SrcBlend", (int)UnityEngine.Rendering.BlendMode.SrcAlpha);
                previewMeshMaterial.SetInt("_DstBlend", (int)UnityEngine.Rendering.BlendMode.OneMinusSrcAlpha);
                previewMeshMaterial.SetInt("_Cull", (int)UnityEngine.Rendering.CullMode.Off);
                previewMeshMaterial.SetInt("_ZWrite", 0);
                previewMeshMaterial.SetInt("_ZTest", (int)UnityEngine.Rendering.CompareFunction.LessEqual);
            }
        }

        if (previewMeshMaterial == null) return;

        previewMeshMaterial.SetPass(0);
        previewMeshMaterial.color = new Color(0f, 1f, 0f, 0.25f);

        foreach (MeshFilter meshFilter in meshFilters)
        {
            if (meshFilter.sharedMesh == null) continue;

            Vector3 localOffset = meshFilter.transform.position - selected.transform.position;
            Vector3 previewPosition = hit.point + localOffset;
            Matrix4x4 matrix = Matrix4x4.TRS(previewPosition, rotation * Quaternion.Inverse(selected.transform.rotation) * meshFilter.transform.rotation, meshFilter.transform.lossyScale);
            Graphics.DrawMeshNow(meshFilter.sharedMesh, matrix);
        }
    }

    private static void HandleMeasureMode(Event e, SceneView sceneView)
    {
        if (!measureMode || sceneView == null) return;

        if (e.type == EventType.MouseDown && e.button == 0 && !e.alt)
        {
            Ray ray = HandleUtility.GUIPointToWorldRay(e.mousePosition);
            object snap = HandleUtility.RaySnap(ray);
            if (snap is RaycastHit hit)
            {
                if (!hasMeasurePointA)
                {
                    measurePointA = hit.point;
                    hasMeasurePointA = true;
                    hasMeasurePointB = false;
                    lastMeasureDistance = 0f;
                }
                else
                {
                    measurePointB = hit.point;
                    hasMeasurePointB = true;
                    lastMeasureDistance = Vector3.Distance(measurePointA, measurePointB);
                }

                e.Use();
                SceneView.RepaintAll();
            }
        }

        if (e.type == EventType.KeyDown && e.keyCode == KeyCode.Escape)
        {
            hasMeasurePointA = false;
            hasMeasurePointB = false;
            lastMeasureDistance = 0f;
            e.Use();
            SceneView.RepaintAll();
        }

        DrawMeasurePreview();
    }

    private static void DrawMeasurePreview()
    {
        if (!measureMode) return;

        Handles.color = Color.yellow;
        if (hasMeasurePointA)
        {
            Handles.SphereHandleCap(0, measurePointA, Quaternion.identity, 0.05f, EventType.Repaint);
        }

        if (hasMeasurePointB)
        {
            Handles.SphereHandleCap(0, measurePointB, Quaternion.identity, 0.05f, EventType.Repaint);
            Handles.DrawLine(measurePointA, measurePointB);
            Vector3 center = (measurePointA + measurePointB) * 0.5f;
            Handles.Label(center, $"{lastMeasureDistance:F2} m");
        }
    }

    private static void HandleWASDMode(Event e, SceneView sceneView)
    {
        if (!wasdMode || Selection.activeGameObject == null || sceneView == null) return;
        if (e.type != EventType.KeyDown) return;

        Transform t = Selection.activeGameObject.transform;
        Vector3 movement = Vector3.zero;

        Vector3 forward = Vector3.ProjectOnPlane(sceneView.camera.transform.forward, Vector3.up).normalized;
        Vector3 right = Vector3.ProjectOnPlane(sceneView.camera.transform.right, Vector3.up).normalized;

        switch (e.keyCode)
        {
            case KeyCode.W: movement = forward * moveSpeed; break;
            case KeyCode.S: movement = -forward * moveSpeed; break;
            case KeyCode.A: movement = -right * moveSpeed; break;
            case KeyCode.D: movement = right * moveSpeed; break;
            case KeyCode.Q: movement = Vector3.up * moveSpeed; break;
            case KeyCode.E: movement = Vector3.down * moveSpeed; break;
            default: return;
        }

        Undo.RecordObject(t, "WASD Move");
        t.position += movement;

        if (autoSnap)
        {
            SnapObject(t.gameObject);
        }
        else
        {
            SnapToGrid(t.transform.position, GetGridSize(), true);
        }

        SceneView.RepaintAll();
        e.Use();
    }

    private static void HandleMouseClick(Event e)
    {
        if (e.type != EventType.MouseDown || e.button != 0 || e.alt) return;

        GameObject selected = Selection.activeGameObject;
        if (selected == null) return;

        Ray ray = HandleUtility.GUIPointToWorldRay(e.mousePosition);
        object snap = HandleUtility.RaySnap(ray);

        if (snap is RaycastHit hit)
        {
            if (collisionCheck && WouldCollide(selected, hit.point))
            {
                Debug.LogWarning("Collision detected! Placement prevented.");
                return;
            }

            Undo.RecordObject(selected.transform, "Quick Move");

            if (modularSnapMode && TryModularSnap(selected, hit.point))
            {
                e.Use();
                return;
            }

            selected.transform.position = hit.point;

            if (alignToNormal)
            {
                AlignObjectToNormal(selected, hit.normal);
            }

            SnapObject(selected);
            e.Use();
        }
    }

    private static bool WouldCollide(GameObject obj, Vector3 targetPosition)
    {
        Renderer rend = obj.GetComponentInChildren<Renderer>();
        if (rend == null) return false;

        Vector3 originalPosition = obj.transform.position;
        obj.transform.position = targetPosition;

        Collider[] overlaps = Physics.OverlapBox(
            rend.bounds.center,
            rend.bounds.extents * 0.95f,
            obj.transform.rotation);

        bool collision = false;
        foreach (Collider col in overlaps)
        {
            if (col == null || col.transform == obj.transform || col.transform.IsChildOf(obj.transform))
                continue;

            collision = true;
            break;
        }

        obj.transform.position = originalPosition;
        return collision;
    }

    private static void HandleAutoSnap()
    {
        if (!autoSnap) return;

        foreach (GameObject obj in Selection.gameObjects)
        {
            if (obj.transform.hasChanged)
            {
                obj.transform.hasChanged = false;
                SnapObject(obj);
            }
        }
    }

    private static void AlignObjectToNormal(GameObject obj, Vector3 normal)
    {
        // Full alignment to surface normal
        obj.transform.rotation = Quaternion.FromToRotation(Vector3.up, normal);

        /* Alternative: Keep Y rotation, only adjust X and Z
        Vector3 forward = Vector3.ProjectOnPlane(obj.transform.forward, normal);
        if (forward != Vector3.zero)
        {
            obj.transform.rotation = Quaternion.LookRotation(forward, normal);
        }
        */
    }

    private static void SnapSelection()
    {
        foreach (GameObject obj in Selection.gameObjects)
        {
            SnapObject(obj);
        }
    }

    private static void SnapObject(GameObject obj)
    {
        Renderer rend = obj.GetComponentInChildren<Renderer>();
        if (rend == null) return;

        Bounds bounds = rend.bounds;
        Vector3 origin = new Vector3(
            bounds.center.x,
            bounds.max.y + 1000f,
            bounds.center.z
        );

        RaycastHit[] hits = Physics.RaycastAll(origin, Vector3.down, 5000f);

        float bestHit = float.NegativeInfinity;
        bool found = false;

        foreach (RaycastHit hit in hits)
        {
            if (hit.transform == obj.transform || 
                hit.transform.IsChildOf(obj.transform))
                continue;

            if (hit.point.y > bestHit)
            {
                bestHit = hit.point.y;
                found = true;
            }
        }

        if (!found) return;

        float offset = obj.transform.position.y - bounds.min.y;
        Vector3 pos = obj.transform.position;
        pos.y = bestHit + offset;
        pos = SnapToGrid(pos, GetGridSize(), false);
        obj.transform.position = pos;
    }
}
