            EditorPrefs.SetBool("QM_CollisionCheck", collisionCheck);
            EditorPrefs.SetBool("QM_AutoSnap", autoSnap);
            EditorPrefs.SetBool("QM_WASDMode", wasdMode);
            EditorPrefs.SetBool("QM_ModularSnapMode", modularSnapMode);
            EditorPrefs.SetBool("QM_MeasureMode", measureMode);
            EditorPrefs.SetFloat("QM_MoveSpeed", moveSpeed);
            EditorPrefs.SetInt("QM_GridSnapIndex", gridSnapIndex);

            Debug.Log("Quick Move settings saved.");
        }

        GUILayout.Space(15);

        // Status Display
        GUI.color = quickMoveMode ? Color.green : Color.gray;
        GUILayout.Label(quickMoveMode ? "Quick Move: ENABLED" : "Quick Move: DISABLED", EditorStyles.helpBox);

