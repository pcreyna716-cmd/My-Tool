        {
            GUI.color = alignToNormal ? Color.cyan : Color.yellow;
            GUILayout.Label($"Align To Normal: {(alignToNormal ? "ON" : "OFF")}", EditorStyles.helpBox);

            GUI.color = collisionCheck ? Color.red : Color.green;
            GUILayout.Label($"Collision Check: {(collisionCheck ? "ON" : "OFF")}", EditorStyles.helpBox);

            GUI.color = autoSnap ? Color.magenta : Color.gray;
            GUILayout.Label($"Auto Snap: {(autoSnap ? "ON" : "OFF")}", EditorStyles.helpBox);

            GUI.color = wasdMode ? Color.blue : Color.gray;
            GUILayout.Label($"WASD Mode: {(wasdMode ? "ON" : "OFF")} (Speed: {moveSpeed})", EditorStyles.helpBox);

            GUI.color = isEdgeSnapActive ? Color.cyan : Color.gray;
            GUILayout.Label($"Edge Snap: {(isEdgeSnapActive ? "ACTIVE" : "INACTIVE")}", EditorStyles.helpBox);
