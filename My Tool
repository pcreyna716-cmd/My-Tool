    private static bool alignToNormal = true;
    private static bool collisionCheck = true;
    private static bool autoSnap = true;
    private static bool wasdMode;
    private static float moveSpeed = 1f;
    private static int gridSnapIndex;
    private static bool modularSnapMode;
    private static bool measureMode;

    private static readonly float[] gridSnapSizes = { 0.25f, 0.5f, 1f, 5f };
    private static readonly string[] gridSnapLabels =
    {
        "0.25m Props",
        "0.5m Small Buildings",
        "1m Buildings",
        "5m Large Structures"
    };

    private static KeyCode snapKey;
    private static KeyCode quickMoveKey;
    private static KeyCode edgeSnapKey = KeyCode.V;

    // Edge Snap variables
    private static bool isEdgeSnapActive;
    private static MeshFilter sourceMeshFilter;
    private static int sourceEdgeMeshIndex = -1;
    private static Vector3 sourceEdgeA;
    private static Vector3 sourceEdgeB;
    private static Vector3 targetEdgeA;
    private static Vector3 targetEdgeB;
    private static bool hasTargetEdge;

    // Measure variables
    private static Vector3 measurePointA;
    private static Vector3 measurePointB;
    private static bool hasMeasurePointA;
    private static bool hasMeasurePointB;
    private static float lastMeasureDistance;

    private static Material previewMeshMaterial;

    [InitializeOnLoadMethod]
