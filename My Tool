    private static void OnSceneGUI(SceneView sceneView)
    {
        Event e = Event.current;
        HandleKeyboardShortcuts(e);


        if (!quickMoveMode && !measureMode) return;

        if (quickMoveMode)
        {
            DrawGUI(e);
            DrawPlacementPreview(e);
            HandleWASDMode(e, sceneView);
            HandleMouseClick(e);
            HandleAutoSnap();
        }

        if (measureMode)
        {
            HandleMeasureMode(e, sceneView);
        }
    }

    private static void HandleKeyboardShortcuts(Event e)
    {
        if (e.keyCode == snapKey && e.type == EventType.KeyDown)
        {
            SnapSelection();
            e.Use();
            return;
        }

        if (e.keyCode == quickMoveKey && e.type == EventType.KeyDown)
        {
            quickMoveMode = !quickMoveMode;
            Debug.Log(quickMoveMode ? "Quick Move Enabled" : "Quick Move Disabled");
            e.Use();
            return;
        }

        if (e.keyCode == edgeSnapKey)
        {
            if (e.type == EventType.KeyDown)
            {
                BeginEdgeSnap(e.mousePosition);
                e.Use();
            }
            else if (e.type == EventType.KeyUp && isEdgeSnapActive)
            {
                CompleteEdgeSnap();
                ClearEdgeSnap();
                e.Use();
            }
        }
    }

    private static void HandleEdgeSnap(SceneView sceneView, Event e)
    {
        if (!isEdgeSnapActive || Selection.activeGameObject == null) return;

        if (e.type == EventType.MouseMove || e.type == EventType.Repaint)
        {
            UpdateTargetEdge(e.mousePosition);
            sceneView.Repaint();
        }

        if (sourceEdgeA != Vector3.zero && sourceEdgeB != Vector3.zero)
        {
            Handles.color = Color.yellow;
            Handles.DrawLine(sourceEdgeA, sourceEdgeB);

            if (hasTargetEdge)
            {
                Handles.color = Color.cyan;
                Handles.DrawLine(targetEdgeA, targetEdgeB);
                Handles.DrawDottedLine(sourceEdgeA, targetEdgeA, 2f);
            }
        }
    }

    private static void BeginEdgeSnap(Vector2 mousePosition)
    {
        GameObject selected = Selection.activeGameObject;
        if (selected == null) return;

        sourceMeshFilter = selected.GetComponentInChildren<MeshFilter>();
        if (sourceMeshFilter == null || sourceMeshFilter.sharedMesh == null)
        {
            isEdgeSnapActive = false;
            return;
        }

        if (!TryFindClosestEdge(sourceMeshFilter, mousePosition, out sourceEdgeA, out sourceEdgeB))
        {
            isEdgeSnapActive = false;
            return;
        }

        hasTargetEdge = false;
        targetEdgeA = Vector3.zero;
        targetEdgeB = Vector3.zero;
        isEdgeSnapActive = true;
    }

    private static void UpdateTargetEdge(Vector2 mousePosition)
    {
        GameObject selected = Selection.activeGameObject;
        if (selected == null) return;

        MeshFilter[] meshFilters = selected.scene
            .GetRootGameObjects()
            .SelectMany(x => x.GetComponentsInChildren<MeshFilter>())
            .ToArray();

        float minDistance = float.MaxValue;
        hasTargetEdge = false;

        foreach (MeshFilter meshFilter in meshFilters)
        {
            if (meshFilter == null || meshFilter.sharedMesh == null) continue;
            if (meshFilter.transform == sourceMeshFilter.transform || meshFilter.transform.IsChildOf(sourceMeshFilter.transform)) continue;
            if (meshFilter.transform.IsChildOf(selected.transform) || selected.transform.IsChildOf(meshFilter.transform)) continue;

            if (TryFindClosestEdge(meshFilter, mousePosition, out Vector3 edgeA, out Vector3 edgeB))
            {
                Vector2 midPoint = (HandleUtility.WorldToGUIPoint(edgeA) + HandleUtility.WorldToGUIPoint(edgeB)) * 0.5f;
                float distance = Vector2.Distance(midPoint, mousePosition);

                if (distance < minDistance)
                {
                    minDistance = distance;
                    hasTargetEdge = true;
                    targetEdgeA = edgeA;
                    targetEdgeB = edgeB;
                }
            }
        }
    }

    private static bool TryFindClosestEdge(MeshFilter meshFilter, Vector2 mousePosition, out Vector3 edgeA, out Vector3 edgeB)
    {
        edgeA = Vector3.zero;
        edgeB = Vector3.zero;
        if (meshFilter == null || meshFilter.sharedMesh == null) return false;

        Mesh mesh = meshFilter.sharedMesh;
        int[] triangles = mesh.triangles;
        Vector3[] vertices = mesh.vertices;
        var seen = new HashSet<long>();

        float minDistance = float.MaxValue;
        bool found = false;

        for (int i = 0; i < triangles.Length; i += 3)
        {
            int[] edgeIndices = { triangles[i], triangles[i + 1], triangles[i + 2] };
            for (int j = 0; j < 3; j++)
            {
                int aIndex = edgeIndices[j];
                int bIndex = edgeIndices[(j + 1) % 3];
                int min = Mathf.Min(aIndex, bIndex);
                int max = Mathf.Max(aIndex, bIndex);
                long key = ((long)min << 32) | (uint)max;
                if (!seen.Add(key)) continue;

                Vector3 worldA = meshFilter.transform.TransformPoint(vertices[aIndex]);
                Vector3 worldB = meshFilter.transform.TransformPoint(vertices[bIndex]);
                Vector2 screenA = HandleUtility.WorldToGUIPoint(worldA);
                Vector2 screenB = HandleUtility.WorldToGUIPoint(worldB);
                float distance = DistancePointToSegment(mousePosition, screenA, screenB);

                if (distance < minDistance && distance < 30f)
                {
                    minDistance = distance;
                    found = true;
                    edgeA = worldA;
                    edgeB = worldB;
                }
            }
        }

        return found;
    }

    private static float DistancePointToSegment(Vector2 point, Vector2 a, Vector2 b)
    {
        Vector2 ab = b - a;
        float t = Mathf.Clamp01(Vector2.Dot(point - a, ab) / Vector2.Dot(ab, ab));
        Vector2 projection = a + ab * t;
        return Vector2.Distance(point, projection);
    }

    private static int FindClosestVertex(MeshFilter meshFilter, Vector2 mousePosition, out Vector3 vertexWorld)
    {
        vertexWorld = Vector3.zero;
        if (meshFilter == null || meshFilter.sharedMesh == null) return -1;

        Vector3[] vertices = meshFilter.sharedMesh.vertices;
        float minDistance = float.MaxValue;
        int foundIndex = -1;

        for (int i = 0; i < vertices.Length; i++)
        {
            Vector3 worldVertex = meshFilter.transform.TransformPoint(vertices[i]);
            Vector2 screenPoint = HandleUtility.WorldToGUIPoint(worldVertex);
            float distance = Vector2.Distance(screenPoint, mousePosition);
            if (distance < minDistance && distance < 30f)
            {
                minDistance = distance;
                foundIndex = i;
                vertexWorld = worldVertex;
            }
        }

        return foundIndex;
    }

    private static void CompleteEdgeSnap()
    {
        if (!hasTargetEdge || Selection.activeGameObject == null) return;

        GameObject selected = Selection.activeGameObject;
        Undo.RecordObject(selected.transform, "Edge Snap");

        Vector3 sourceDir = (sourceEdgeB - sourceEdgeA).normalized;
        Vector3 targetDir = (targetEdgeB - targetEdgeA).normalized;
        Quaternion rotationAdjustment = Quaternion.FromToRotation(sourceDir, targetDir);

        Vector3 rotatedSourceA = rotationAdjustment * (sourceEdgeA - selected.transform.position) + selected.transform.position;
        Vector3 offset = targetEdgeA - rotatedSourceA;

        selected.transform.rotation = rotationAdjustment * selected.transform.rotation;
        selected.transform.position += offset;

        SnapObject(selected);
    }

    private static void ClearEdgeSnap()
    {
        sourceEdgeA = Vector3.zero;
        sourceEdgeB = Vector3.zero;
        targetEdgeA = Vector3.zero;
        targetEdgeB = Vector3.zero;
        hasTargetEdge = false;
        isEdgeSnapActive = false;
        SceneView.RepaintAll();
    }

    private static float GetGridSize()
    {
        return gridSnapIndex >= 0 && gridSnapIndex < gridSnapSizes.Length ? gridSnapSizes[gridSnapIndex] : 1f;
    }

    private static Vector3 SnapToGrid(Vector3 position, float gridSize, bool snapY)
    {
        if (gridSize <= 0f) return position;
        position.x = Mathf.Round(position.x / gridSize) * gridSize;
        position.z = Mathf.Round(position.z / gridSize) * gridSize;
        if (snapY)
        {
            position.y = Mathf.Round(position.y / gridSize) * gridSize;
        }
        return position;
    }

    private static bool TryModularSnap(GameObject selected, Vector3 hitPoint)
    {
        ModularSnapPoint[] sourcePoints = selected.GetComponentsInChildren<ModularSnapPoint>(true);
        if (sourcePoints.Length == 0) return false;

        ModularSnapPoint bestSource = null;
        float bestSourceDistance = float.MaxValue;
        foreach (var source in sourcePoints)
        {
            float distance = Vector3.Distance(source.transform.position, hitPoint);
            if (distance < bestSourceDistance)
            {
                bestSourceDistance = distance;
                bestSource = source;
            }
        }

        if (bestSource == null) return false;

        ModularSnapPoint[] targetPoints = GetSceneModularSnapPoints(selected);
        if (targetPoints.Length == 0) return false;

        ModularSnapPoint bestTarget = null;
        float bestMatch = float.MaxValue;
        foreach (var target in targetPoints)
        {
            if (target == null) continue;
            if (target == bestSource) continue;
            if (target.transform.IsChildOf(selected.transform) || selected.transform.IsChildOf(target.transform)) continue;

            float directionScore = 1f - Mathf.Abs(Vector3.Dot(bestSource.transform.forward, -target.transform.forward));
            float distanceScore = Vector3.Distance(bestSource.transform.position, target.transform.position);
            float score = directionScore * 2f + distanceScore * 0.02f;
            if (score < bestMatch)
            {
                bestMatch = score;
                bestTarget = target;
            }
        }

        if (bestTarget == null) return false;

        Quaternion rotationAdjustment = Quaternion.FromToRotation(bestSource.transform.forward, -bestTarget.transform.forward);
        Quaternion finalRotation = rotationAdjustment * selected.transform.rotation;
        Vector3 localSource = bestSource.transform.position - selected.transform.position;
        Vector3 rotatedSourceOffset = finalRotation * localSource;
        Vector3 desiredPosition = bestTarget.transform.position - rotatedSourceOffset;

        selected.transform.rotation = finalRotation;
        selected.transform.position = desiredPosition;
        return true;
    }

    private static ModularSnapPoint[] GetSceneModularSnapPoints(GameObject selected)
    {
        return selected.scene.GetRootGameObjects()
            .SelectMany(root => root.GetComponentsInChildren<ModularSnapPoint>(true))
            .Where(point => point != null && !point.transform.IsChildOf(selected.transform) && point.transform.root != selected.transform.root)
            .ToArray();
    }

