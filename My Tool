    {
        snapKey = (KeyCode)EditorPrefs.GetInt("QM_SnapKey", (int)KeyCode.End);
        quickMoveKey = (KeyCode)EditorPrefs.GetInt("QM_MoveKey", (int)KeyCode.Q);
        alignToNormal = EditorPrefs.GetBool("QM_AlignToNormal", true);
        collisionCheck = EditorPrefs.GetBool("QM_CollisionCheck", true);
        autoSnap = EditorPrefs.GetBool("QM_AutoSnap", true);
        wasdMode = EditorPrefs.GetBool("QM_WASDMode", false);
        modularSnapMode = EditorPrefs.GetBool("QM_ModularSnapMode", false);
        measureMode = EditorPrefs.GetBool("QM_MeasureMode", false);
        moveSpeed = EditorPrefs.GetFloat("QM_MoveSpeed", 1f);
        gridSnapIndex = EditorPrefs.GetInt("QM_GridSnapIndex", 2);

        SceneView.duringSceneGui -= OnSceneGUI;
        SceneView.duringSceneGui += OnSceneGUI;
    }

    private void OnDisable()
    {
        SceneView.duringSceneGui -= OnSceneGUI;
    }

    [MenuItem("Tools/Quick Move Tool")]
    public static void ShowWindow()
    {
        GetWindow<QuickMoveTool>("Quick Move Tool");
    }

